# Supabase - Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: set this in production so Supabase email confirmation links always
# point to your public site. Leave unset for local LAN/mobile testing.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# DeepSeek AI - optional server-side default.
# Open-source users can also enter their own key inside Command Center.
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional comma-separated allowlist for user-supplied OpenAI-compatible base URLs.
# Leave empty to allow only https://api.deepseek.com and DEEPSEEK_BASE_URL.
AI_ALLOWED_BASE_URLS=
