# Supabase - Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: set this in production so Supabase email confirmation links always
# point to your public site. Leave unset for local LAN/mobile testing.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# DeepSeek AI - server-side default for LOGGED-IN users.
# Guests (trial) must enter their own key in Command Center; logged-in users get this for free.
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Kimi / Moonshot AI - second server-side model for LOGGED-IN users (switchable in Command Center).
KIMI_API_KEY=your-kimi-moonshot-api-key-here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-32k

# Optional comma-separated allowlist for user-supplied OpenAI-compatible base URLs.
# Moonshot is allowed so BYO Kimi keys work. Leave empty to allow only the presets.
AI_ALLOWED_BASE_URLS=https://api.moonshot.cn/v1

# Optional server-only comma-separated allowlist for internal test accounts that
# should see all language modules and lessons unlocked.
FULL_UNLOCK_EMAILS=
