# Supabase - Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: set this in production so Supabase email confirmation links always
# point to your public site. Leave unset for local LAN/mobile testing.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# DeepSeek AI - Get from platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here
